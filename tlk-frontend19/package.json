{
  "name": "tlk-frontend19",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "api:pull": "node ./openapi/pull-openapi.mjs",
    "api:gen": "openapi-generator-cli generate -i openapi/openapi.yaml -g typescript-angular -o src/app/api --additional-properties=ngVersion=19,providedInRoot=true",
    "api:sync": "npm run api:pull && npm run api:gen"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^19.2.18",
    "@angular/common": "^19.2.0",
    "@angular/compiler": "^19.2.0",
    "@angular/core": "^19.2.0",
    "@angular/forms": "^19.2.0",
    "@angular/platform-browser": "^19.2.0",
    "@angular/platform-browser-dynamic": "^19.2.0",
    "@angular/router": "^19.2.0",
    "@drv-ds/drv-design-system-ng": "file:./libs/drv-design-system-ng-7.20.1.tgz",
    "openapi-generator-cli": "^1.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.20",
    "@angular/cli": "^19.2.20",
    "@angular/compiler-cli": "^19.2.0",
    "@openapitools/openapi-generator-cli": "^2.30.1",
    "@types/jasmine": "~5.1.0",
    "jasmine-core": "~5.6.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.7.2"
  }
}
